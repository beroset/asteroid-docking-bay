"""asteroid-docking-bay launcher.

The implementation lives in the asteroid_docking_bay package (see
docs/ARCHITECTURE.md). This script only locates it — next to this file in a
repo checkout, or under ~/.local/share/asteroid-docking-bay/lib when
installed by install.sh — and hands over to cli.main().
"""

import sys
from pathlib import Path

_here = Path(__file__).resolve().parent
for _cand in (_here.parent,                                          # repo checkout
              Path.home() / ".local/share/asteroid-docking-bay/lib"):  # install.sh
    if (_cand / "asteroid_docking_bay" / "__init__.py").is_file():
        sys.path.insert(0, str(_cand))
        break

try:
    from asteroid_docking_bay.cli import main
except ImportError as e:
    sys.stderr.write(
        f"asteroid-docking-bay: cannot find its package ({e}).\n"
        "Run from a repo checkout, or (re)install with ./install.sh\n")
    sys.exit(1)

if __name__ == "__main__":
    main()
